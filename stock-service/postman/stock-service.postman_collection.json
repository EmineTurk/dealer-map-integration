{
  "info": {
    "_postman_id": "7ed339b8-58a2-4f13-b836-a215f11b4704",
    "name": "Stock Service - Complete API",
    "description": "Cumulative Stock Service collection for project Days 1-12. Requests follow docs/api-contract.md.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "productId",
      "value": "1"
    },
    {
      "key": "storeId",
      "value": "1"
    },
    {
      "key": "unknownProductId",
      "value": "99"
    },
    {
      "key": "unknownStoreId",
      "value": "999"
    },
    {
      "key": "lat",
      "value": "40.9901"
    },
    {
      "key": "lng",
      "value": "29.0253"
    },
    {
      "key": "radius",
      "value": "10"
    }
  ],
  "item": [
    {
      "name": "01 - Health",
      "item": [
        {
          "name": "GET Actuator Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Service is healthy', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Products",
      "item": [
        {
          "name": "GET Product Catalog",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Product catalog follows the contract', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "  if (body.length > 0) {",
                  "    pm.expect(body[0]).to.have.all.keys('id', 'name', 'sku', 'category');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Product Store Search",
      "item": [
        {
          "name": "GET Nearby Stores With Stock",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}/stores?lat={{lat}}&lng={{lng}}&radius={{radius}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}",
                "stores"
              ],
              "query": [
                {
                  "key": "lat",
                  "value": "{{lat}}"
                },
                {
                  "key": "lng",
                  "value": "{{lng}}"
                },
                {
                  "key": "radius",
                  "value": "{{radius}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Stock search follows the contract', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "  body.forEach(store => {",
                  "    pm.expect(store).to.have.property('distance');",
                  "    pm.expect(store).to.have.property('stockLevel');",
                  "    pm.expect(store).not.to.have.property('quantity');",
                  "  });",
                  "});",
                  "",
                  "pm.test('Results are sorted by distance', function () {",
                  "  const distances = pm.response.json().map(store => store.distance);",
                  "  const sorted = [...distances].sort((a, b) => a - b);",
                  "  pm.expect(distances).to.eql(sorted);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Unknown Product - 404",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{unknownProductId}}/stores?lat={{lat}}&lng={{lng}}&radius={{radius}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{unknownProductId}}",
                "stores"
              ],
              "query": [
                {
                  "key": "lat",
                  "value": "{{lat}}"
                },
                {
                  "key": "lng",
                  "value": "{{lng}}"
                },
                {
                  "key": "radius",
                  "value": "{{radius}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Unknown product returns shared 404 error', function () {",
                  "  pm.response.to.have.status(404);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql(404);",
                  "  pm.expect(body.message).to.eql('Product not found: id=' + pm.variables.get('unknownProductId'));",
                  "  pm.expect(body).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Missing Radius - 400",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}/stores?lat={{lat}}&lng={{lng}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}",
                "stores"
              ],
              "query": [
                {
                  "key": "lat",
                  "value": "{{lat}}"
                },
                {
                  "key": "lng",
                  "value": "{{lng}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Missing radius returns shared 400 error', function () {",
                  "  pm.response.to.have.status(400);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql(400);",
                  "  pm.expect(body.message).to.eql('Missing request parameter: radius');",
                  "  pm.expect(body).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 - Stock Updates",
      "item": [
        {
          "name": "PUT Existing Stock - 204",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 4\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}/stores/{{storeId}}/stock",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}",
                "stores",
                "{{storeId}}",
                "stock"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Existing stock is updated', function () {",
                  "  pm.response.to.have.status(204);",
                  "  pm.expect(pm.response.text()).to.eql('');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT Negative Quantity - 400",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": -1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}/stores/{{storeId}}/stock",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}",
                "stores",
                "{{storeId}}",
                "stock"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Negative quantity returns shared 400 error', function () {",
                  "  pm.response.to.have.status(400);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql(400);",
                  "  pm.expect(body.message).to.eql('Quantity must be zero or greater');",
                  "  pm.expect(body).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT Unknown Stock Record - 404",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 4\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}/stores/{{unknownStoreId}}/stock",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}",
                "stores",
                "{{unknownStoreId}}",
                "stock"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Unknown stock record returns shared 404 error', function () {",
                  "  pm.response.to.have.status(404);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql(404);",
                  "  pm.expect(body.message).to.eql('Stock not found: productId=' + pm.variables.get('productId') + ', storeId=' + pm.variables.get('unknownStoreId'));",
                  "  pm.expect(body).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT Restore Seed Quantity - 204",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 10\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}/stores/{{storeId}}/stock",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}",
                "stores",
                "{{storeId}}",
                "stock"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Seed quantity is restored', function () {",
                  "  pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
